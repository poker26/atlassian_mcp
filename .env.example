# Jira Data Center
JIRA_URL=https://jira.yourcompany.com
JIRA_USER=your.username
JIRA_PAT=REPLACE_WITH_JIRA_PAT

# Confluence Data Center
CONFLUENCE_URL=https://confluence.yourcompany.com
CONFLUENCE_PAT=REPLACE_WITH_CONFLUENCE_PAT

# SSL verification (true / path to CA bundle / false)
SSL_VERIFY=true

# MCP server API key (openssl rand -hex 32)
MCP_API_KEY=REPLACE_WITH_RANDOM_HEX

# Server binding
SERVER_HOST=0.0.0.0
SERVER_PORT=8002
LOG_LEVEL=INFO

# Attachment size limit (bytes) — 2 MB default
MAX_ATTACHMENT_SIZE=2097152
